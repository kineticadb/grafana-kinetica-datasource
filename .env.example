# Kinetica Datasource Plugin - Environment Configuration
# Copy this file to .env and fill in your values
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your actual values
#   docker compose up -d

# Kinetica Connection Settings
# ----------------------------

# Kinetica REST API URL
# For local Kinetica: http://host.docker.internal:9191
# For remote Kinetica: http://your-kinetica-server:9191
KINETICA_URL=http://host.docker.internal:9191

# Database username
KINETICA_USER=admin

# Database password
KINETICA_PASSWORD=your_password_here
